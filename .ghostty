# This is the configuration file for Ghostty.
# File location: $HOME/Library/Application\ Support/com.mitchellh.ghostty/config

# Key bindings
keybind = alt+cmd+left=previous_tab
keybind = alt+cmd+right=next_tab
keybind = shift+enter=text:\x1b\r

keybind = "ctrl+f=write_scrollback_file:open"

# Font
font-family = MesloLGS Nerd Font Mono
font-size = 11

window-inherit-font-size = false

# Styling
macos-titlebar-style = tabs

window-padding-x = 10
window-padding-y = 10

background-opacity = 0.95
background-blur-radius = 20
minimum-contrast = 1.0

# region Theme
# Inspired by `smoooooth` theme from Alacritty.
# Reference: https://github.com/alacritty/alacritty-theme/blob/master/themes/smoooooth.toml
# Primary colors
background = #14191e
foreground = #ffffff

# Cursor
cursor-color = #fefffe
cursor-text = #000000

# Selection
selection-background = #b3d7ff
selection-foreground = #000000

# Normal colors (palette 0-7)
palette = 0=#14191e
palette = 1=#b43c29
palette = 2=#00c200
palette = 3=#c7c400
palette = 4=#2743c7
palette = 5=#bf3fbd
palette = 6=#00c5c7
palette = 7=#c7c7c7

# Bright colors (palette 8-15)
palette = 8=#676767
palette = 9=#dc7974
palette = 10=#57e690
palette = 11=#ece100
palette = 12=#a6aaf1
palette = 13=#e07de0
palette = 14=#5ffdff
palette = 15=#feffff
# endregion Theme